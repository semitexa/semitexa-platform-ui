{#
 # platform.grid — minimal interactive read-only grid shell.
 #
 # Renders a stable component root that the grid runtime
 # (packages/semitexa-platform-ui/src/Application/Static/js/grid-runtime.js)
 # discovers via `[data-ui-grid]`. The runtime fetches JSON from
 # `data-ui-grid-data-url`, populates the tbody via createElement +
 # textContent, intercepts filter form submits + Next-page clicks,
 # and reloads when an SSE refresh-marker patch arrives.
 #
 # Things this template **does not** do:
 #   - it does not know what `q` / `action` / cursor mean — the
 #     filter form lives in the caller's `filters` slot;
 #   - it does not open an SSE connection — when the page opts into
 #     canonical KISS via `ui_page_sse_session_meta('live')` the
 #     event-runtime auto-opens the stream; the grid runtime only
 #     subscribes to the resulting `semitexa:ui-sse:component-state`
 #     document events and reloads when one targets this grid;
 #   - it does not authorize — the data endpoint authorizes;
 #   - it does not project rows — the data endpoint projects safely.
 #
 # Props consumed (see GridComponent docblock for full reference):
 #   gridId               (required string)
 #   instanceId           (optional string; falls back to ui_component_instance())
 #   title                (optional string)
 #   description          (optional string)
 #   dataUrl              (required string)
 #   subscriberChannelId  (optional string; advertised on the root so the
 #                         runtime knows the page opted into canonical KISS.
 #                         Null disables the live-refresh code path.)
 #   refreshMarker        (optional string; default 'grid-refresh-marker')
 #   columns        (required list<{key, label, style?}>)
 #   initialRows    (optional list<map> — server-rendered fallback)
 #   initialPagination (optional {limit, hasMore, nextCursor})
 #   initialQuery   (optional string — fallback Next-link state)
 #   initialAction  (optional string — fallback Next-link state)
 #   pageFallbackUrl   (optional string — no-JS Next-link href base)
 #   emptyMessage   (optional string)
 #   paginationWindowSize (optional int — max visited-page buttons
 #                  rendered in the pagination footer; clamped to
 #                  [1, 25]; default 7. The runtime slides the
 #                  visible window so the active page stays inside.
 #                  Never renders buttons for unknown future pages —
 #                  cursor pagination has no total-count surface.)
 #
 # Slots:
 #   warning      (optional production-warning callout)
 #   filters      (caller-owned filter form — REQUIRED if dynamic
 #                 filter submit is wanted)
 #   filterState  (optional filter-state strip)
 #   footer       (optional caller footer)
 #}
{%- set _grid_id           = gridId|default('grid') -%}
{%- set _grid_instance     = instanceId|default(ui_component_instance()) -%}
{%- set _grid_data_url     = dataUrl|default('') -%}
{%- set _grid_sub_channel  = subscriberChannelId|default(null) -%}
{%- set _grid_refresh_name = refreshMarker|default('grid-refresh-marker') -%}
{%- set _grid_columns_raw  = columns|default([]) -%}
{%- set _grid_initial_rows = initialRows|default([]) -%}
{%- set _grid_pagination   = initialPagination|default({}) -%}
{%- set _grid_limit        = _grid_pagination.limit|default(25) -%}
{%- set _grid_has_more     = _grid_pagination.hasMore|default(false) -%}
{%- set _grid_next_cursor  = _grid_pagination.nextCursor|default(null) -%}
{%- set _grid_initial_q    = initialQuery|default(null) -%}
{%- set _grid_initial_act  = initialAction|default(null) -%}
{%- set _grid_initial_sort = initialSort|default(null) -%}
{%- set _grid_sort_param   = sortParam|default('sort') -%}
{%- set _grid_page_url     = pageFallbackUrl|default('') -%}
{%- set _grid_empty        = emptyMessage|default('No rows.') -%}

{#- Column normalisation. Callers may pass either the legacy explicit
    shape (`{key, label, style?, sortAsc?, sortDesc?}`) or the boot-
    time providerProps shape from `#[AsColumn]`
    (`{key, label, sortable: bool, type: string}`). Normalise to the
    legacy shape: when `sortable: true` and no explicit `sortAsc/_desc`,
    derive `${key}_asc` / `${key}_desc` (the convention the data
    endpoint allow-list already follows); when `type` is set and no
    explicit `style`, map to a sensible default cell style. -#}
{%- set _grid_columns = [] -%}
{%- for _col in _grid_columns_raw -%}
    {%- set _col_key       = _col.key|default(null) -%}
    {%- set _col_sort_asc  = _col.sortAsc|default(null) -%}
    {%- set _col_sort_desc = _col.sortDesc|default(null) -%}
    {%- if (_col_sort_asc is null or _col_sort_asc == '') and (_col_sort_desc is null or _col_sort_desc == '') and _col.sortable|default(false) and _col_key is not null -%}
        {%- set _col_sort_asc  = _col_key ~ '_asc' -%}
        {%- set _col_sort_desc = _col_key ~ '_desc' -%}
    {%- endif -%}
    {%- set _col_style = _col.style|default('') -%}
    {%- if _col_style == '' -%}
        {%- set _col_type = _col.type|default('text') -%}
        {%- if _col_type == 'datetime' or _col_type == 'date' -%}
            {%- set _col_style = 'white-space:nowrap;' -%}
        {%- elseif _col_type == 'mono' -%}
            {%- set _col_style = 'font-family:var(--ui-font-mono);font-size:0.75rem;' -%}
        {%- endif -%}
    {%- endif -%}
    {%- set _grid_columns = _grid_columns|merge([{
        key:      _col_key,
        label:    _col.label|default(_col_key),
        style:    _col_style,
        sortAsc:  _col_sort_asc,
        sortDesc: _col_sort_desc,
    }]) -%}
{%- endfor -%}
{#- Pagination window size — caller-tunable, but clamped + defaulted
    server-side so the rendered data attribute is always a safe
    integer the runtime can trust. The runtime additionally re-
    validates / re-clamps when reading the attribute (defence in
    depth: a hostile DOM injection could still tamper with the
    rendered value at runtime). Negative / non-numeric / iterable
    inputs all collapse to the documented default before clamping
    to [1, 25]. -#}
{%- set _grid_window_raw   = paginationWindowSize|default(7) -%}
{%- if _grid_window_raw is iterable or _grid_window_raw is null -%}
    {%- set _grid_window_raw = 7 -%}
{%- endif -%}
{%- set _grid_window       = (_grid_window_raw|number_format(0, '.', ''))|trim -%}
{%- set _grid_window       = _grid_window matches '/\\A-?\\d+\\z/' ? (_grid_window + 0) : 7 -%}
{%- set _grid_window       = max(1, min(25, _grid_window)) -%}

{#- Build the no-JS-fallback Next-link href from the caller's page
    URL + the initial filter state + the server-issued cursor. The
    runtime overwrites this href on every reload via
    [data-ui-grid-next-cursor]. -#}
{%- set _grid_next_params = {
    cursor: _grid_next_cursor|default(''),
    limit:  _grid_limit,
} -%}
{%- if _grid_initial_q is not null and _grid_initial_q != '' -%}
    {%- set _grid_next_params = _grid_next_params|merge({ q: _grid_initial_q }) -%}
{%- endif -%}
{%- if _grid_initial_act is not null and _grid_initial_act != '' -%}
    {%- set _grid_next_params = _grid_next_params|merge({ action: _grid_initial_act }) -%}
{%- endif -%}
{%- if _grid_initial_sort is not null and _grid_initial_sort != '' -%}
    {%- set _grid_next_params = _grid_next_params|merge({ (_grid_sort_param): _grid_initial_sort }) -%}
{%- endif -%}
{%- set _grid_next_fallback_href = _grid_page_url ~ '?' -%}
{%- for k, v in _grid_next_params -%}
    {%- set _grid_next_fallback_href = _grid_next_fallback_href ~ k ~ '=' ~ v|url_encode -%}
    {%- if not loop.last -%}{%- set _grid_next_fallback_href = _grid_next_fallback_href ~ '&' -%}{%- endif -%}
{%- endfor -%}

<div
    data-ui-component="platform.grid"
    data-ui-component-instance-id="{{ _grid_instance }}"
    data-ui-grid="{{ _grid_id }}"
    data-ui-grid-data-url="{{ _grid_data_url }}"
    {% if _grid_sub_channel is not null and _grid_sub_channel != '' %}data-ui-grid-subscriber-channel-id="{{ _grid_sub_channel }}"{% endif %}
    data-ui-grid-refresh-marker="{{ _grid_refresh_name }}"
    data-ui-grid-pagination-window-size="{{ _grid_window }}"
    sx-layout="stack" sx-gap="2"
>
    {#- Hidden patch target retained for the legacy refresh-marker
        contract callers can still send via `setText`. The canonical
        KISS path ignores this element — it routes by component
        instance id, not by patch target name. -#}
    <span data-ui-patch-target="{{ _grid_refresh_name }}" hidden aria-hidden="true"></span>

    {%- if title|default(null) is not null %}
        <header sx-layout="stack" sx-gap="1">
            <h2 ui-text="title" style="margin:0;font-size:1.5rem;">{{ title }}</h2>
            {%- if description|default(null) is not null %}
                <p ui-text="muted" style="margin:0;max-width:48rem;">{{ description }}</p>
            {%- endif %}
        </header>
    {%- endif %}

    {%- set _warning_slot = slot('warning')|default('')|trim %}
    {%- if _warning_slot != '' %}
        {{ slot('warning')|raw }}
    {%- endif %}

    {%- if _grid_sub_channel is not null and _grid_sub_channel != '' %}
        <p data-ui-grid-live-indicator hidden ui-text="muted"
           style="margin:0;font-size:0.8125rem;color:var(--ui-state-success);"
           aria-live="polite">Live updates connected.</p>
    {%- endif %}

    <p data-ui-grid-error hidden ui-text="muted"
       sx-surface="panel" sx-padding="3" sx-radius="md"
       style="margin:0;border-left:4px solid var(--ui-state-danger);"
       aria-live="polite"></p>

    {#- Filter form — caller-owned slot has precedence. The runtime
        selects `[data-ui-grid-form]` inside the grid root to intercept
        submits. The slot's markup MUST include that attribute. -#}
    {%- set _filters_slot = slot('filters')|default('')|trim %}
    {%- if _filters_slot != '' %}
        {{ slot('filters')|raw }}
    {%- else %}
        {#- Structured-filter auto-render. Activates only when no
            `filters` slot was supplied AND the caller passes a
            structured `filters` prop (list of
            `{field, type, placeholder, label}` entries — the shape
            emitted by GridComponentMetadataProvider from
            `#[AsFilter]`). Select options come from an optional
            `filterOptions` map keyed by field; when absent, the
            select renders with a single empty default option (the
            filter stays visually present but is a no-op until the
            caller supplies options). Current values come from an
            optional `currentFilters` map keyed by field. Page-size
            selector is rendered from `pagination.limitOptions` when
            present. -#}
        {%- set _grid_filters_struct = filters|default([]) -%}
        {%- set _grid_pagination_struct = pagination|default({}) -%}
        {%- set _grid_limit_options     = _grid_pagination_struct.limitOptions|default([]) -%}
        {%- set _grid_filter_options    = filterOptions|default({}) -%}
        {%- set _grid_current_filters   = currentFilters|default({}) -%}
        {%- set _grid_has_struct_filters = false -%}
        {%- if _grid_filters_struct is iterable and _grid_filters_struct|length > 0 -%}
            {%- for _f in _grid_filters_struct -%}
                {%- if _f.field|default(null) is not null -%}
                    {%- set _grid_has_struct_filters = true -%}
                {%- endif -%}
            {%- endfor -%}
        {%- endif -%}
        {%- if _grid_has_struct_filters or _grid_limit_options|length > 0 -%}
            {%- set _grid_any_filter_active = false -%}
            {%- for _f in _grid_filters_struct -%}
                {%- if _f.field|default(null) is not null -%}
                    {%- set _v = _grid_current_filters[_f.field]|default(null) -%}
                    {%- if _v is not null and _v != '' -%}
                        {%- set _grid_any_filter_active = true -%}
                    {%- endif -%}
                {%- endif -%}
            {%- endfor -%}
            <form data-ui-grid-form method="get" action="{{ _grid_page_url }}"
                  sx-surface="panel" sx-padding="3" sx-radius="md" sx-layout="cluster" sx-gap="2" sx-align="end"
                  style="flex-wrap:wrap;">
                {%- if _grid_initial_sort is not null and _grid_initial_sort != '' %}
                    <input type="hidden" name="{{ _grid_sort_param }}" value="{{ _grid_initial_sort }}">
                {%- endif %}
                {%- if _grid_has_struct_filters %}
                    {%- for _f in _grid_filters_struct %}
                        {%- if _f.field|default(null) is not null %}
                            {%- set _f_field = _f.field -%}
                            {%- set _f_type  = _f.type|default('search') -%}
                            {%- set _f_label = _f.label|default('') -%}
                            {%- set _f_ph    = _f.placeholder|default('') -%}
                            {%- set _f_value = _grid_current_filters[_f_field]|default('') -%}
                            <label sx-layout="stack" sx-gap="1"
                                   style="{% if _f_type == 'search' %}min-width:18rem;flex:1 1 18rem;{% else %}min-width:14rem;{% endif %}">
                                <span ui-text="label" style="font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">{{ _f_label != '' ? _f_label : _f_field }}</span>
                                {%- if _f_type == 'select' %}
                                    <select name="{{ _f_field }}"
                                            style="padding:0.5rem 0.75rem;border:1px solid var(--ui-border-subtle);border-radius:var(--ui-radius-sm);font-size:0.875rem;">
                                        {%- set _f_options = _grid_filter_options[_f_field]|default([]) -%}
                                        {%- if _f_options|length == 0 %}
                                            <option value=""{% if _f_value == '' %} selected{% endif %}>{{ _f_ph != '' ? _f_ph : 'All' }}</option>
                                        {%- else %}
                                            {%- for _opt in _f_options %}
                                                {%- set _opt_value = _opt.value|default('') -%}
                                                {%- set _opt_label = _opt.label|default(_opt_value) -%}
                                                <option value="{{ _opt_value }}"{% if _opt_value == _f_value %} selected{% endif %}>{{ _opt_label }}</option>
                                            {%- endfor %}
                                        {%- endif %}
                                    </select>
                                {%- else %}
                                    <input type="{{ _f_type == 'search' ? 'search' : 'text' }}" name="{{ _f_field }}"
                                           value="{{ _f_value }}"
                                           {% if _f_ph != '' %}placeholder="{{ _f_ph }}"{% endif %}
                                           maxlength="100"
                                           style="padding:0.5rem 0.75rem;border:1px solid var(--ui-border-subtle);border-radius:var(--ui-radius-sm);font-size:0.875rem;">
                                {%- endif %}
                            </label>
                        {%- endif %}
                    {%- endfor %}
                {%- endif %}
                {%- if _grid_limit_options|length > 0 %}
                    <label sx-layout="stack" sx-gap="1" style="min-width:7rem;">
                        <span ui-text="label" style="font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">Page size</span>
                        <select name="limit" data-ui-grid-reload-on-change
                                style="padding:0.5rem 0.75rem;border:1px solid var(--ui-border-subtle);border-radius:var(--ui-radius-sm);font-size:0.875rem;">
                            {%- for _opt in _grid_limit_options %}
                                <option value="{{ _opt }}"{% if _opt == _grid_limit %} selected{% endif %}>{{ _opt }}</option>
                            {%- endfor %}
                        </select>
                    </label>
                {%- endif %}
                {%- if _grid_has_struct_filters %}
                    <button type="submit"
                            style="padding:0.5rem 1rem;border:0;border-radius:var(--ui-radius-sm);background:var(--ui-action-primary);color:var(--ui-action-on-primary);font-size:0.875rem;cursor:pointer;">
                        Filter
                    </button>
                    {%- if _grid_any_filter_active %}
                        <a href="{{ _grid_page_url }}" data-ui-grid-clear ui-text="muted" style="font-size:0.875rem;text-decoration:none;">Clear</a>
                    {%- endif %}
                {%- endif %}
            </form>
        {%- endif %}
    {%- endif %}

    {%- set _filter_state_slot = slot('filterState')|default('')|trim %}
    {%- if _filter_state_slot != '' %}
        {{ slot('filterState')|raw }}
    {%- endif %}

    {#- Empty state — visible when there are no initial rows. The
        runtime toggles `hidden` after every reload. -#}
    <section data-ui-grid-empty
             {% if _grid_initial_rows|length > 0 %}hidden{% endif %}
             sx-surface="panel" sx-padding="5" sx-radius="md" sx-layout="stack" sx-gap="2">
        <strong ui-text="label">{{ _grid_empty }}</strong>
    </section>

    {#- Table wrap — server-rendered fallback. Visible only when
        initial rows are present; the runtime toggles after reloads. -#}
    <section data-ui-grid-table-wrap
             {% if _grid_initial_rows|length == 0 %}hidden{% endif %}
             sx-layout="stack" sx-gap="2">
        <p data-ui-grid-pagination-text ui-text="muted" style="margin:0;font-size:0.8125rem;">
            Page size <code data-ui-grid-pagination-size>{{ _grid_limit }}</code> —
            showing <span data-ui-grid-pagination-count>{{ _grid_initial_rows|length }}</span>
            <span data-ui-grid-pagination-label>row{{ _grid_initial_rows|length == 1 ? '' : 's' }}</span>.
            <strong data-ui-grid-pagination-more {% if not _grid_has_more %}hidden{% endif %}>(more available)</strong>
            <em data-ui-grid-pagination-last {% if _grid_has_more %}hidden{% endif %}>(last page)</em>
        </p>
        <div sx-surface="panel" sx-radius="md" style="overflow:auto;">
            <table style="width:100%;border-collapse:collapse;">
                <thead>
                    <tr style="background:var(--ui-surface-sunken);">
                        {%- for col in _grid_columns %}
                            {%- set _col_sort_asc  = col.sortAsc|default(null) -%}
                            {%- set _col_sort_desc = col.sortDesc|default(null) -%}
                            {%- set _col_sortable  = (_col_sort_asc is not null and _col_sort_asc != '') and (_col_sort_desc is not null and _col_sort_desc != '') -%}
                            {%- if _col_sortable -%}
                                {#- A column is the active sort target if the current
                                    initialSort matches either of its two allow-listed
                                    tokens. The "next" toggle flips between the two; if
                                    neither is active yet, the first click goes to DESC
                                    (the conventional date-like default). -#}
                                {%- if _grid_initial_sort == _col_sort_asc -%}
                                    {%- set _col_sort_state = 'ascending' -%}
                                    {%- set _col_next_sort  = _col_sort_desc -%}
                                {%- elseif _grid_initial_sort == _col_sort_desc -%}
                                    {%- set _col_sort_state = 'descending' -%}
                                    {%- set _col_next_sort  = _col_sort_asc -%}
                                {%- else -%}
                                    {%- set _col_sort_state = 'none' -%}
                                    {%- set _col_next_sort  = _col_sort_desc -%}
                                {%- endif -%}
                                {#- Toggle href is the page URL with the current
                                    filter state + the toggled sort token + NO cursor
                                    (sort changes invalidate the cursor's fingerprint
                                    anyway). -#}
                                {%- set _col_toggle_params = { (_grid_sort_param): _col_next_sort, limit: _grid_limit } -%}
                                {%- if _grid_initial_q is not null and _grid_initial_q != '' -%}
                                    {%- set _col_toggle_params = _col_toggle_params|merge({ q: _grid_initial_q }) -%}
                                {%- endif -%}
                                {%- if _grid_initial_act is not null and _grid_initial_act != '' -%}
                                    {%- set _col_toggle_params = _col_toggle_params|merge({ action: _grid_initial_act }) -%}
                                {%- endif -%}
                                {%- set _col_toggle_href = _grid_page_url ~ '?' -%}
                                {%- for k, v in _col_toggle_params -%}
                                    {%- set _col_toggle_href = _col_toggle_href ~ k ~ '=' ~ v|url_encode -%}
                                    {%- if not loop.last -%}{%- set _col_toggle_href = _col_toggle_href ~ '&' -%}{%- endif -%}
                                {%- endfor -%}
                                <th ui-text="label" aria-sort="{{ _col_sort_state }}"
                                    style="text-align:left;padding:0.5rem 0.75rem;font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">
                                    <a data-ui-grid-sort
                                       data-ui-grid-sort-key="{{ col.key }}"
                                       data-ui-grid-sort-asc="{{ _col_sort_asc }}"
                                       data-ui-grid-sort-desc="{{ _col_sort_desc }}"
                                       href="{{ _col_toggle_href }}"
                                       style="color:inherit;text-decoration:none;display:inline-flex;align-items:center;gap:0.25rem;">
                                        <span>{{ col.label|default(col.key) }}</span>
                                        <span data-ui-grid-sort-indicator aria-hidden="true" style="font-size:0.6875rem;opacity:0.7;">
                                            {%- if _col_sort_state == 'ascending' -%}▲
                                            {%- elseif _col_sort_state == 'descending' -%}▼
                                            {%- else -%}↕
                                            {%- endif -%}
                                        </span>
                                    </a>
                                </th>
                            {%- else -%}
                                <th ui-text="label" style="text-align:left;padding:0.5rem 0.75rem;font-size:0.75rem;letter-spacing:0.04em;text-transform:uppercase;">{{ col.label|default(col.key) }}</th>
                            {%- endif -%}
                        {%- endfor %}
                    </tr>
                </thead>
                <tbody data-ui-grid-tbody>
                    {%- for row in _grid_initial_rows %}
                        <tr style="border-top:1px solid var(--ui-border-subtle);"
                            {% if row.id|default(null) is not null %}data-ui-grid-row-id="{{ row.id }}"{% endif %}>
                            {%- for col in _grid_columns %}
                                <td ui-text="body" style="padding:0.5rem 0.75rem;font-size:0.8125rem;{{ col.style|default('') }}">
                                    {{- attribute(row, col.key)|default('') -}}
                                </td>
                            {%- endfor %}
                        </tr>
                    {%- endfor %}
                </tbody>
            </table>
        </div>
        {#- Pagination footer: Previous / current page / visited-page
            buttons / Next. Layout collapses cleanly on no-JS — the
            server only renders Next (cursor pagination is forward-
            only without total counts or offset support), and the
            runtime progressively enhances it with Previous + visited-
            page buttons sourced from a client-side cursor history
            stack tied to the active criteria fingerprint.

            The buttons stay inside the existing `[data-ui-grid-table-
            wrap]` so they hide together with the table on the empty-
            state branch. -#}
        <nav data-ui-grid-pagination
             aria-label="Grid pagination"
             sx-layout="cluster" sx-gap="2" sx-align="center"
             style="margin:0;flex-wrap:wrap;font-size:0.875rem;">

            {#- Previous: rendered hidden on first paint; runtime
                reveals it whenever the client-side history stack
                has more than one entry. No no-JS fallback href —
                cursors are forward-only on the server. -#}
            <button type="button" data-ui-grid-prev
                    hidden
                    style="padding:0.25rem 0.625rem;border:1px solid var(--ui-border-subtle);background:var(--ui-surface-raised);border-radius:var(--ui-radius-sm);font-size:0.8125rem;cursor:pointer;color:inherit;">
                ← Previous page
            </button>

            {#- Visited-page numbered buttons. The runtime appends
                a `<button data-ui-grid-page="N">` for every page
                whose cursor it has actually seen (page 1 is always
                present because its cursor is the implicit null).
                Server renders nothing here — the initial state is
                always page 1, and the runtime fills the first
                button in on boot. -#}
            <span data-ui-grid-pages sx-layout="cluster" sx-gap="1" sx-align="center"
                  style="display:inline-flex;flex-wrap:wrap;gap:0.25rem;"></span>

            {#- Current-page indicator. The runtime overwrites the
                inner text via textContent on every reload. The
                server-rendered fallback always reads "Page 1"
                because cursors are forward-only and the server
                doesn't track client-side history. -#}
            <span data-ui-grid-page-indicator ui-text="muted"
                  style="font-size:0.8125rem;">Page 1</span>

            <span data-ui-grid-next-wrap
                  {% if not _grid_has_more or _grid_next_cursor is null %}hidden{% endif %}>
                <a data-ui-grid-next
                   {% if _grid_has_more and _grid_next_cursor is not null %}data-ui-grid-next-cursor="{{ _grid_next_cursor }}"{% endif %}
                   href="{{ _grid_next_fallback_href }}"
                   style="padding:0.25rem 0.625rem;border:1px solid var(--ui-border-subtle);background:var(--ui-surface-raised);border-radius:var(--ui-radius-sm);text-decoration:none;color:inherit;">Next page →</a>
            </span>
        </nav>
    </section>

    {%- set _footer_slot = slot('footer')|default('')|trim %}
    {%- if _footer_slot != '' %}
        {{ slot('footer')|raw }}
    {%- endif %}

    {#- Inline JSON bundle the runtime reads to discover the column
        order + cell styles + refresh-marker name. Lives BELOW the
        table so DOMContentLoaded discovers it together with the
        grid root. -#}
    <script type="application/json" data-ui-grid-bundle="{{ _grid_id }}">
{{ {
    "gridId":              _grid_id,
    "instanceId":          _grid_instance,
    "dataUrl":             _grid_data_url,
    "subscriberChannelId": _grid_sub_channel,
    "refreshMarker":       _grid_refresh_name,
    "columns":             _grid_columns,
    "pageFallbackUrl":     _grid_page_url,
    "initialSort":         _grid_initial_sort,
    "sortParam":           _grid_sort_param,
    "initialPagination":   _grid_pagination,
}|json_encode|raw }}
    </script>
</div>
